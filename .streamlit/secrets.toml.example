# Streamlit Secrets Template
# 
# For Streamlit Community Cloud deployment:
# 1. Go to your app settings on Streamlit Cloud
# 2. Navigate to "Secrets" section
# 3. Copy the content below and fill in your actual credentials
# 4. DO NOT commit this file with real credentials!

[dhan]
client_id = "your_dhan_client_id"
access_token = "your_dhan_access_token"

[upstox]
client_id = "your_upstox_client_id"
client_secret = "your_upstox_client_secret"
access_token = "your_upstox_access_token"

[fyers]
client_id = "your_fyers_client_id"
access_token = "your_fyers_access_token"
